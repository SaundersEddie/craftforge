---
export const prerender = false;

import { env } from "cloudflare:workers";
import "../../styles/global.css";
import ThemeScript from "../../components/ThemeScript.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";

type ProductListItem = {
  id: number;
  name: string;
  product_type: string;
  material: string | null;
  dimensions: string | null;
  status: string;
  created_at: string;
};

const result = await env.DB
  .prepare(
    `SELECT id, name, product_type, material, dimensions, status, created_at
     FROM products
     ORDER BY created_at DESC`
  )
  .all<ProductListItem>();

const products = result.results ?? [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>CraftForge Products</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
  </head>

  <body>
    <main class="page-shell">
      <section class="hero">
        <div>
          <p class="eyebrow">CraftForge</p>
          <h1>Product Library</h1>
          <p class="lede">
            Turn real maker notes into listing copy, launch packs, photo checklists,
            and practical improvement notes.
          </p>
        </div>

        <div class="hero-actions">
          <ThemeToggle />
          <a class="primary-action" href="/products/new">Add Product</a>
        </div>
      </section>

      <section class="summary-card">
        <div>
          <span class="summary-number">{products.length}</span>
          <span class="summary-label">
            {products.length === 1 ? "product saved" : "products saved"}
          </span>
        </div>

        <p>
          v0.1 target: add product → save product → generate launch pack → use it for
          a real Brindle listing.
        </p>
      </section>

      {
        products.length === 0 ? (
          <section class="empty-state">
            <h2>No products saved yet</h2>
            <p>
              Add the first real product and start building the launch workflow.
            </p>
            <a class="primary-action" href="/products/new">Add Product</a>
          </section>
        ) : (
          <section class="product-grid" aria-label="Saved products">
            {products.map((product) => (
              <article class="product-card">
                <div class="card-topline">
                  <span class="status-pill">{product.status}</span>
                  <span class="created-at">{product.created_at}</span>
                </div>

                <h2>
                  <a href={`/products/${product.id}`}>{product.name}</a>
                </h2>

                <dl>
                  <div>
                    <dt>Type</dt>
                    <dd>{product.product_type}</dd>
                  </div>

                  <div>
                    <dt>Material</dt>
                    <dd>{product.material ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Dimensions</dt>
                    <dd>{product.dimensions ?? "Not set"}</dd>
                  </div>
                </dl>

                <a class="card-link" href={`/products/${product.id}`}>
                  View product →
                </a>
              </article>
            ))}
          </section>
        )
      }
    </main>
  </body>
</html>

<style>

  .hero-actions {
    display: grid;
    gap: 0.8rem;
    justify-items: end;
  }

  @media (max-width: 720px) {
    .hero-actions {
      justify-items: stretch;
    }
  }
  .hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .lede {
    max-width: 680px;
    margin: 1rem 0 0;
    color: #cfc7ba;
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .summary-card,
  .empty-state,
  .product-card {
    border: 1px solid rgba(244, 240, 232, 0.12);
    background: rgba(22, 24, 31, 0.78);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
    backdrop-filter: blur(14px);
  }


  .summary-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
  }

  .summary-label {
    color: #cfc7ba;
    font-size: 0.9rem;
  }

  .summary-card p {
    max-width: 620px;
    margin: 0;
    color: #cfc7ba;
    line-height: 1.5;
  }

  .empty-state h2 {
    margin-top: 0;
    font-size: 1.8rem;
  }

  .empty-state p {
    color: #cfc7ba;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .product-card:hover {
    border-color: rgba(229, 123, 53, 0.45);
  }

  .card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .status-pill {
    border: 1px solid rgba(229, 123, 53, 0.4);
    border-radius: 999px;
    padding: 0.28rem 0.6rem;
    color: #ffd2b6;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .created-at {
    color: #92897d;
    font-size: 0.75rem;
  }

  .product-card h2 {
    margin: 0 0 1rem;
    font-size: 1.45rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .product-card h2 a {
    text-decoration: none;
  }

  .product-card h2 a:hover {
    color: #e57b35;
  }

  dl {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 1.25rem;
  }

  dl div {
    display: grid;
    gap: 0.15rem;
  }

  dt {
    color: #92897d;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  dd {
    margin: 0;
    color: #f4f0e8;
  }

  .card-link {
    margin-top: auto;
    align-self: flex-start;
    border: 1px solid rgba(244, 240, 232, 0.18);
    padding: 0.65rem 0.9rem;
    color: #f4f0e8;
  }

  .card-link:hover {
    border-color: rgba(229, 123, 53, 0.6);
    background: rgba(229, 123, 53, 0.12);
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(100% - 1rem, 1120px);
      padding: 1rem 0 2rem;
    }

    .hero,
    .summary-card {
      align-items: stretch;
      flex-direction: column;
    }

    .primary-action {
      width: 100%;
    }

    .product-card {
      min-height: auto;
    }
  }
</style>
