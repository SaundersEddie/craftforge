---
export const prerender = false;

import { env } from "cloudflare:workers";
import "../../styles/global.css";
import ThemeScript from "../../components/ThemeScript.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import {
  PRODUCT_STATUSES,
  PRODUCT_STATUS_LABELS,
  getProductStatusLabel,
  type ProductStatus,
} from "../../lib/productStatus";

type ProductListItem = {
  id: number;
  name: string;
  product_type: string;
  material: string | null;
  dimensions: string | null;
  status: string;
  created_at: string;
};

const statusParam = Astro.url.searchParams.get("status");

const selectedStatus =
  statusParam && PRODUCT_STATUSES.includes(statusParam as ProductStatus)
    ? (statusParam as ProductStatus)
    : null;

const result = selectedStatus
  ? await env.DB
      .prepare(
        `SELECT id, name, product_type, material, dimensions, status, created_at
         FROM products
         WHERE status = ?
         ORDER BY created_at DESC`
      )
      .bind(selectedStatus)
      .all<ProductListItem>()
  : await env.DB
      .prepare(
        `SELECT id, name, product_type, material, dimensions, status, created_at
         FROM products
         ORDER BY created_at DESC`
      )
      .all<ProductListItem>();

const products = result.results ?? [];

function statusUrl(status: ProductStatus | null) {
  return status ? `/products?status=${status}` : "/products";
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>CraftForge Products</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
  </head>

  <body>
    <main class="page-shell">
      <section class="hero">
        <div>
          <p class="eyebrow">CraftForge</p>
          <h1>Product Library</h1>
          <p class="lede">
            Turn real maker notes into listing copy, launch packs, photo checklists,
            and practical improvement notes.
          </p>
        </div>

        <div class="hero-actions">
          <ThemeToggle />
          <a class="primary-action" href="/products/new">Add Product</a>
        </div>
      </section>

      <section class="summary-card product-summary">
        <div>
          <span class="summary-number">{products.length}</span>
          <span class="summary-label">
            {products.length === 1 ? "product shown" : "products shown"}
          </span>
        </div>

        <p>
          {selectedStatus
            ? `Filtered by status: ${getProductStatusLabel(selectedStatus)}`
            : "Showing all saved products."}
        </p>
      </section>

      <section class="filter-panel">
        <p class="eyebrow">Filter by status</p>

        <div class="status-filter-list">
          <a
            class={selectedStatus === null ? "status-filter active" : "status-filter"}
            href={statusUrl(null)}
          >
            All
          </a>

          {
            PRODUCT_STATUSES.map((status) => (
              <a
                class={selectedStatus === status ? "status-filter active" : "status-filter"}
                href={statusUrl(status)}
              >
                {PRODUCT_STATUS_LABELS[status]}
              </a>
            ))
          }
        </div>
      </section>

      {
        products.length === 0 ? (
          <section class="empty-state">
            <h2>No products found</h2>
            <p>
              {selectedStatus
                ? "No products currently match this status."
                : "Add the first real product and start building the launch workflow."}
            </p>
            <a class="primary-action" href="/products/new">Add Product</a>
          </section>
        ) : (
          <section class="product-grid" aria-label="Saved products">
            {products.map((product) => (
              <article class="product-card">
                <div class="card-topline">
                  <span class="status-pill">{getProductStatusLabel(product.status)}</span>
                  <span class="created-at">{product.created_at}</span>
                </div>

                <h2>
                  <a href={`/products/${product.id}`}>{product.name}</a>
                </h2>

                <dl>
                  <div>
                    <dt>Type</dt>
                    <dd>{product.product_type}</dd>
                  </div>

                  <div>
                    <dt>Material</dt>
                    <dd>{product.material ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Dimensions</dt>
                    <dd>{product.dimensions ?? "Not set"}</dd>
                  </div>
                </dl>

                <a class="card-link" href={`/products/${product.id}`}>
                  View product →
                </a>
              </article>
            ))}
          </section>
        )
      }
    </main>
  </body>
</html>

<style>
  .hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .hero-actions {
    display: grid;
    gap: 0.8rem;
    justify-items: end;
  }

  .product-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1rem;
    padding: 1rem 1.2rem;
  }

  .summary-number {
    display: block;
    color: var(--text);
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1;
  }

  .summary-label {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .product-summary p {
    max-width: 620px;
    margin: 0;
    color: var(--muted);
    line-height: 1.5;
  }

  .filter-panel {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: var(--surface-soft);
  }

  .status-filter-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .status-filter {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    padding: 0.45rem 0.75rem;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
  }

  .status-filter:hover,
  .status-filter.active {
    border-color: var(--accent-border);
    background: var(--accent-soft);
    color: var(--text);
  }

  .empty-state {
    padding: 2rem;
  }

  .empty-state h2 {
    margin-top: 0;
    font-size: 1.8rem;
  }

  .empty-state p {
    color: var(--muted);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .product-card {
    display: flex;
    min-height: 280px;
    flex-direction: column;
    padding: 1.2rem;
  }

  .product-card:hover {
    border-color: var(--accent-border);
  }

  .card-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .status-pill {
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-pill);
    padding: 0.28rem 0.6rem;
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .created-at {
    color: var(--muted-strong);
    font-size: 0.75rem;
  }

  .product-card h2 {
    margin: 0 0 1rem;
    font-size: 1.45rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .product-card h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .product-card h2 a:hover {
    color: var(--accent);
  }

  dl {
    display: grid;
    gap: 0.75rem;
    margin: 0 0 1.25rem;
  }

  dl div {
    display: grid;
    gap: 0.15rem;
  }

  .card-link {
    margin-top: auto;
    align-self: flex-start;
  }

  @media (max-width: 720px) {
    .hero,
    .product-summary {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions {
      justify-items: stretch;
    }

    .primary-action {
      width: 100%;
    }

    .product-card {
      min-height: auto;
    }
  }
</style>
