---
export const prerender = false;

import { env } from "cloudflare:workers";
import "../../styles/global.css";
import ThemeScript from "../../components/ThemeScript.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import { calculateListingHealth } from "../../lib/listingHealth";

type Product = {
  id: number;
  name: string;
  product_type: string;
  material: string | null;
  dimensions: string | null;
  production_time_minutes: number | null;
  estimated_cost_cents: number | null;
  target_price_cents: number | null;
  color_options: string | null;
  finish_options: string | null;
  customization_rules: string | null;
  shipping_notes: string | null;
  care_notes: string | null;
  photo_notes: string | null;
  status: string;
  created_at: string;
  updated_at: string;
};

type LaunchPack = {
  id: number;
  product_id: number;
  etsy_title: string | null;
  short_description: string | null;
  long_description: string | null;
  etsy_tags_json: string | null;
  facebook_post: string | null;
  website_blurb: string | null;
  photo_checklist_json: string | null;
  improvement_notes_json: string | null;
  health_score: number | null;
  created_at: string;
};

function formatCents(value: number | null) {
  if (value === null) return "Not set";
  return `$${(value / 100).toFixed(2)}`;
}

function formatMinutes(value: number | null) {
  if (value === null) return "Not set";
  return `${value} minutes`;
}

function parseJsonList(value: string | null) {
  if (!value) return [];

  try {
    const parsed = JSON.parse(value);

    if (!Array.isArray(parsed)) {
      return [];
    }

    return parsed.filter((item): item is string => typeof item === "string");
  } catch {
    return [];
  }
}

const id = Astro.params.id;

if (!id) {
  return Astro.redirect("/products");
}

const product = await env.DB
  .prepare(
    `SELECT
      id,
      name,
      product_type,
      material,
      dimensions,
      production_time_minutes,
      estimated_cost_cents,
      target_price_cents,
      color_options,
      finish_options,
      customization_rules,
      shipping_notes,
      care_notes,
      photo_notes,
      status,
      created_at,
      updated_at
    FROM products
    WHERE id = ?`
  )
  .bind(id)
  .first<Product>();

const launchPackResult = product
  ? await env.DB
      .prepare(
        `SELECT
          id,
          product_id,
          etsy_title,
          short_description,
          long_description,
          etsy_tags_json,
          facebook_post,
          website_blurb,
          photo_checklist_json,
          improvement_notes_json,
          health_score,
          created_at
        FROM launch_packs
        WHERE product_id = ?
        ORDER BY created_at DESC`
      )
      .bind(product.id)
      .all<LaunchPack>()
  : { results: [] };

const launchPacks = launchPackResult.results ?? [];
const health = product ? calculateListingHealth(product) : null;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{product ? `${product.name} | CraftForge` : "Product not found | CraftForge"}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
  </head>

  <body>
    <main class="page-shell">
      <div class="top-row">
        <a class="back-link" href="/products">← Back to products</a>
        <ThemeToggle />
      </div>

      {
        !product ? (
          <section class="panel not-found-panel">
            <h1>Product not found</h1>
            <p class="muted">That product does not exist, or it has been removed.</p>
          </section>
        ) : (
          <>
            <section class="hero">
              <div>
                <p class="eyebrow">Product detail</p>
                <h1>{product.name}</h1>
                <p class="lede">
                  {product.product_type} · {product.material ?? "Material not set"} ·{" "}
                  {product.status}
                </p>
              </div>

              <div class="hero-action">
                <button id="generate-launch-pack" type="button" data-product-id={product.id}>
                  Generate Launch Pack
                </button>
                <p id="launch-pack-message" aria-live="polite"></p>
              </div>
            </section>

            <section class="dashboard-grid">
              <article class="panel health-panel">
                <div class="panel-heading">
                  <div>
                    <p class="eyebrow">Listing health</p>
                    <h2>{health ? `${health.percentage}%` : "N/A"}</h2>
                  </div>

                  {health && <span class="score-chip">{health.score}/{health.maxScore}</span>}
                </div>

                {
                  health && (
                    <>
                      {health.warnings.length > 0 && (
                        <div class="warning-box">
                          <h3>Warnings</h3>
                          <ul>
                            {health.warnings.map((warning) => (
                              <li>{warning}</li>
                            ))}
                          </ul>
                        </div>
                      )}

                      <h3>Checks</h3>
                      <ul class="check-list">
                        {health.checks.map((check) => (
                          <li class={check.passed ? "pass" : "needs-work"}>
                            <span>{check.passed ? "✓" : "!"}</span>
                            <p>{check.message}</p>
                          </li>
                        ))}
                      </ul>
                    </>
                  )
                }
              </article>

              <article class="panel">
                <p class="eyebrow">Core details</p>
                <dl class="detail-list">
                  <div>
                    <dt>Type</dt>
                    <dd>{product.product_type}</dd>
                  </div>

                  <div>
                    <dt>Material</dt>
                    <dd>{product.material ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Dimensions</dt>
                    <dd>{product.dimensions ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Production time</dt>
                    <dd>{formatMinutes(product.production_time_minutes)}</dd>
                  </div>

                  <div>
                    <dt>Estimated cost</dt>
                    <dd>{formatCents(product.estimated_cost_cents)}</dd>
                  </div>

                  <div>
                    <dt>Target price</dt>
                    <dd>{formatCents(product.target_price_cents)}</dd>
                  </div>
                </dl>
              </article>

              <article class="panel">
                <p class="eyebrow">Options and rules</p>
                <dl class="detail-list">
                  <div>
                    <dt>Color options</dt>
                    <dd>{product.color_options ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Finish options</dt>
                    <dd>{product.finish_options ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Customization rules</dt>
                    <dd>{product.customization_rules ?? "Not set"}</dd>
                  </div>
                </dl>
              </article>

              <article class="panel">
                <p class="eyebrow">Listing notes</p>
                <dl class="detail-list">
                  <div>
                    <dt>Shipping notes</dt>
                    <dd>{product.shipping_notes ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Care notes</dt>
                    <dd>{product.care_notes ?? "Not set"}</dd>
                  </div>

                  <div>
                    <dt>Photo notes</dt>
                    <dd>{product.photo_notes ?? "Not set"}</dd>
                  </div>
                </dl>
              </article>
            </section>

            <section class="launch-pack-section">
              <div class="section-heading">
                <p class="eyebrow">Generated output</p>
                <h2>Saved launch packs</h2>
                <p class="muted">
                  Saved snapshots from this product’s notes. AI can come later; the display
                  structure already knows how to hold the output.
                </p>
              </div>

              {
                launchPacks.length === 0 ? (
                  <article class="panel">
                    <h3>No launch packs generated yet</h3>
                    <p class="muted">
                      Generate one from this product’s saved notes to test the full workflow.
                    </p>
                  </article>
                ) : (
                  <div class="launch-pack-list">
                    {launchPacks.map((pack) => {
                      const tags = parseJsonList(pack.etsy_tags_json);
                      const photoChecklist = parseJsonList(pack.photo_checklist_json);
                      const improvementNotes = parseJsonList(pack.improvement_notes_json);

                      return (
                        <article class="panel launch-pack-card">
                          <div class="launch-pack-header">
                            <div>
                              <p class="eyebrow">Launch Pack #{pack.id}</p>
                              <h3>{pack.etsy_title ?? "Untitled launch pack"}</h3>

                              {
                                pack.etsy_title && (
                                  <button
                                    class="copy-button"
                                    type="button"
                                    data-copy-text={pack.etsy_title}
                                  >
                                    Copy Etsy title
                                  </button>
                                )
                              }
                            </div>

                            <div class="score-pill">
                              {pack.health_score === null ? "No score" : `${pack.health_score}%`}
                            </div>
                          </div>

                          <p class="muted">Created: {pack.created_at}</p>

                          <div class="copy-block">
                            <div class="copy-block-header">
                              <h4>Short description</h4>
                              {
                                pack.short_description && (
                                  <button
                                    class="copy-button"
                                    type="button"
                                    data-copy-text={pack.short_description}
                                  >
                                    Copy
                                  </button>
                                )
                              }
                            </div>
                            <p>{pack.short_description ?? "Not set"}</p>
                          </div>

                          <div class="copy-block">
                            <div class="copy-block-header">
                              <h4>Long description</h4>
                              {
                                pack.long_description && (
                                  <button
                                    class="copy-button"
                                    type="button"
                                    data-copy-text={pack.long_description}
                                  >
                                    Copy
                                  </button>
                                )
                              }
                            </div>
                            <pre>{pack.long_description ?? "Not set"}</pre>
                          </div>

                          <div class="copy-block">
                            <div class="copy-block-header">
                              <h4>Etsy tags</h4>
                              {
                                tags.length > 0 && (
                                  <button
                                    class="copy-button"
                                    type="button"
                                    data-copy-text={tags.join(", ")}
                                  >
                                    Copy tags
                                  </button>
                                )
                              }
                            </div>

                            {tags.length === 0 ? (
                              <p class="muted">No tags saved.</p>
                            ) : (
                              <div class="tag-list">
                                {tags.map((tag) => (
                                  <span>{tag}</span>
                                ))}
                              </div>
                            )}
                          </div>

                          <div class="copy-grid">
                            <div class="copy-block">
                              <div class="copy-block-header">
                                <h4>Facebook post</h4>
                                {
                                  pack.facebook_post && (
                                    <button
                                      class="copy-button"
                                      type="button"
                                      data-copy-text={pack.facebook_post}
                                    >
                                      Copy
                                    </button>
                                  )
                                }
                              </div>
                              <pre>{pack.facebook_post ?? "Not set"}</pre>
                            </div>

                            <div class="copy-block">
                              <div class="copy-block-header">
                                <h4>Website blurb</h4>
                                {
                                  pack.website_blurb && (
                                    <button
                                      class="copy-button"
                                      type="button"
                                      data-copy-text={pack.website_blurb}
                                    >
                                      Copy
                                    </button>
                                  )
                                }
                              </div>
                              <p>{pack.website_blurb ?? "Not set"}</p>
                            </div>
                          </div>

                          <div class="copy-grid">
                            <div class="copy-block">
                              <div class="copy-block-header">
                                <h4>Photo checklist</h4>
                                {
                                  photoChecklist.length > 0 && (
                                    <button
                                      class="copy-button"
                                      type="button"
                                      data-copy-text={photoChecklist.join("\n")}
                                    >
                                      Copy
                                    </button>
                                  )
                                }
                              </div>

                              {photoChecklist.length === 0 ? (
                                <p class="muted">No photo checklist saved.</p>
                              ) : (
                                <ul>
                                  {photoChecklist.map((item) => (
                                    <li>{item}</li>
                                  ))}
                                </ul>
                              )}
                            </div>

                            <div class="copy-block">
                              <div class="copy-block-header">
                                <h4>Improvement notes</h4>
                                {
                                  improvementNotes.length > 0 && (
                                    <button
                                      class="copy-button"
                                      type="button"
                                      data-copy-text={improvementNotes.join("\n")}
                                    >
                                      Copy
                                    </button>
                                  )
                                }
                              </div>

                              {improvementNotes.length === 0 ? (
                                <p class="muted">No improvement notes saved.</p>
                              ) : (
                                <ul>
                                  {improvementNotes.map((note) => (
                                    <li>{note}</li>
                                  ))}
                                </ul>
                              )}
                            </div>
                          </div>
                        </article>
                      );
                    })}
                  </div>
                )
              }
            </section>

            <p class="timestamp">
              Created: {product.created_at}
              <br />
              Updated: {product.updated_at}
            </p>
          </>
        )
      }
    </main>

    <script>
      type LaunchPackResult = {
        id?: number;
        message?: string;
        error?: string;
      };

      const button = document.querySelector<HTMLButtonElement>("#generate-launch-pack");
      const message = document.querySelector<HTMLParagraphElement>("#launch-pack-message");

      button?.addEventListener("click", async () => {
        const productId = button.dataset.productId;

        if (!productId) {
          if (message) {
            message.textContent = "Missing product id.";
          }

          return;
        }

        button.disabled = true;

        if (message) {
          message.textContent = "Generating launch pack...";
        }

        const response = await fetch("/api/launch-packs/generate", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            product_id: Number(productId),
          }),
        });

        const result = (await response.json()) as LaunchPackResult;

        if (!response.ok) {
          if (message) {
            message.textContent = result.error ?? "Something went wrong.";
          }

          button.disabled = false;
          return;
        }

        window.location.reload();
      });

      const copyButtons = document.querySelectorAll<HTMLButtonElement>("[data-copy-text]");

      copyButtons.forEach((copyButton) => {
        copyButton.addEventListener("click", async () => {
          const textToCopy = copyButton.dataset.copyText;

          if (!textToCopy) {
            return;
          }

          try {
            await navigator.clipboard.writeText(textToCopy);

            const originalText = copyButton.textContent;
            copyButton.textContent = "Copied";

            window.setTimeout(() => {
              copyButton.textContent = originalText;
            }, 1200);
          } catch {
            const originalText = copyButton.textContent;
            copyButton.textContent = "Copy failed";

            window.setTimeout(() => {
              copyButton.textContent = originalText;
            }, 1200);
          }
        });
      });
    </script>
  </body>
</html>

<style>
  .top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .back-link {
    margin-bottom: 0;
  }

  .not-found-panel {
    padding: 1.2rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .hero-action {
    display: grid;
    gap: 0.7rem;
    justify-items: end;
  }

  #launch-pack-message {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: 1rem;
    align-items: start;
    margin-bottom: 2rem;
  }

  .panel {
    padding: 1.2rem;
  }

  .health-panel {
    grid-row: span 3;
  }

  .panel-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .panel-heading h2 {
    margin: 0;
    color: var(--text);
    font-size: 3rem;
    line-height: 1;
  }

  .score-chip,
  .score-pill {
    min-width: max-content;
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-pill);
    padding: 0.45rem 0.75rem;
    color: var(--accent);
    font-weight: 900;
  }

  .warning-box {
    border: 1px solid var(--accent-border);
    border-radius: var(--radius-md);
    margin: 1rem 0;
    padding: 1rem;
    background: var(--accent-soft);
  }

  .warning-box h3 {
    margin-bottom: 0.5rem;
  }

  .warning-box li {
    color: var(--text);
    line-height: 1.45;
  }

  .check-list {
    display: grid;
    gap: 0.55rem;
    padding: 0;
    list-style: none;
  }

  .check-list li {
    display: grid;
    grid-template-columns: 1.6rem 1fr;
    gap: 0.6rem;
    align-items: start;
    border: 1px solid var(--border);
    border-radius: 0.9rem;
    padding: 0.75rem;
    background: var(--surface-soft);
  }

  .check-list span {
    display: grid;
    width: 1.35rem;
    height: 1.35rem;
    place-items: center;
    border-radius: var(--radius-pill);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .check-list p {
    margin: 0;
    color: var(--muted);
    line-height: 1.45;
  }

  .check-list .pass span {
    background: var(--success-soft);
    color: var(--success-text);
  }

  .check-list .needs-work span {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .detail-list {
    display: grid;
    gap: 0.85rem;
    margin: 0;
  }

  .detail-list div {
    display: grid;
    gap: 0.2rem;
  }

  .launch-pack-section {
    display: grid;
    gap: 1rem;
  }

  .section-heading {
    max-width: 760px;
  }

  .section-heading h2 {
    margin-bottom: 0.3rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .launch-pack-list {
    display: grid;
    gap: 1rem;
  }

  .launch-pack-card {
    display: grid;
    gap: 1rem;
  }

  .launch-pack-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .launch-pack-header h3 {
    margin-bottom: 0.7rem;
    font-size: 1.5rem;
  }

  .copy-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .copy-block {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1rem;
    background: var(--surface-soft);
  }

  .copy-block-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }

  .copy-block h4 {
    margin-bottom: 0;
    color: var(--accent);
  }

  .copy-block p,
  .copy-block li {
    color: var(--muted);
    line-height: 1.55;
  }

  .copy-button {
    width: auto;
    min-width: max-content;
    border: 1px solid var(--border);
    padding: 0.45rem 0.7rem;
    background: var(--surface-soft);
    color: var(--muted);
    box-shadow: none;
    font-size: 0.8rem;
  }

  .copy-button:hover {
    background: var(--accent-soft);
    color: var(--text);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-list span {
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-pill);
    padding: 0.35rem 0.65rem;
    background: var(--surface-soft);
    color: var(--text);
    font-size: 0.9rem;
  }

  .timestamp {
    margin-top: 1.5rem;
    font-size: 0.85rem;
  }

  @media (max-width: 860px) {
    .top-row,
    .hero,
    .dashboard-grid,
    .copy-grid {
      grid-template-columns: 1fr;
    }

    .top-row {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-action {
      justify-items: stretch;
    }

    button {
      width: 100%;
    }

    .copy-button {
      width: auto;
    }

    .health-panel {
      grid-row: auto;
    }
  }

  @media (max-width: 640px) {
    .launch-pack-header,
    .copy-block-header {
      flex-direction: column;
    }
  }
</style>
